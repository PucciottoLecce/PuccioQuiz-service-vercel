{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/test",
      "dest": "/test.html"
    },
    {
      "src": "/ruota",
      "dest": "/ruota.html"
    },
    {
      "src": "/fine",
      "dest": "/fine.html"
    },
    {
      "src": "/perso",
      "dest": "/perso.html"
    },
    {
      "src": "/GDPR",
      "dest": "/GDPR.html"
    },
    {
      "src": "/",
      "dest": "/test.html"
    }
  ]
}